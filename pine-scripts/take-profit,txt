fib1 = input.float(1.272, "Fib TP1", minval = 0.5, step = 0.001, group = grpTiers, inline = "fib1")
fib2 = input.float(1.414, "Fib TP2", minval = 0.5, step = 0.001, group = grpTiers, inline = "fib2")
