     tooltip = "Fibonacci: Uses classic extension levels (1.272, 1.414, 1.618, 2.0, 2.618) projected from the Anchor→Swing leg.\n\nR-Multiples: Uses 1R, 2R, 3R, 5R, 8R based on the Stop Loss distance. Ideal for risk-based position management.\n\nHybrid Confluence: Combines Fibonacci targets with nearby round numbers and pivot S/R levels. Each TP receives a confluence score (★ to ★★★) indicating how many source types align at that price. This is the most robust mode for high-conviction exits.")

anchorMode = input.string("Auto — Pivot High/Low", "Anchor Source",
     options = ["Manual Price", "Auto — Pivot High/Low", "Auto — Recent S/R Zone"],
     group   = grpAnchor,
     tooltip = "Manual: You input Entry, Swing and Stop Loss prices directly.\n\nAuto Pivot: Detects the most recent confirmed pivot high/low using the pivot length. Anchor = last opposite pivot, Swing = last same-direction pivot.\n\nAuto S/R: Anchors the plan to the most recent swing-based support/resistance level.")

pivotLen = input.int(10, "Pivot Length", minval = 2, maxval = 50,
     group   = grpAnchor,
     tooltip = "Bars on each side of a pivot for confirmation. Higher = stronger/slower pivots. 10 is balanced for most intraday and swing timeframes.")

manualEntry = input.price(0.0, "Manual Entry Price",
     group   = grpAnchor,
     tooltip = "Only used when Anchor Source = Manual Price. Your planned entry price.")

manualSwing = input.price(0.0, "Manual Swing / Origin Price",
     group   = grpAnchor,
     tooltip = "Only used when Anchor Source = Manual Price. The origin of the move (prior swing). Direction is auto-detected: Entry > Swing = LONG, Entry < Swing = SHORT.")

manualSL = input.price(0.0, "Manual Stop Loss",
     group   = grpAnchor,
     tooltip = "Only used when Anchor Source = Manual Price. Your planned stop-loss price.")

slMode = input.string("ATR Multiple", "Auto Stop Loss Mode",
     options = ["ATR Multiple", "Swing Point", "Fixed Percent"],
     group   = grpAnchor,
     tooltip = "ATR Multiple: SL = Entry ± (ATR × multiplier).\nSwing Point: SL = the swing price itself (classic structural stop).\nFixed Percent: SL = Entry ± percent.")

atrLen = input.int(14, "ATR Length", minval = 2, group = grpAnchor)
atrMult = input.float(1.5, "ATR Multiplier", minval = 0.1, step = 0.1, group = grpAnchor)
slPct = input.float(1.5, "Fixed SL Percent", minval = 0.1, step = 0.1, group = grpAnchor)

