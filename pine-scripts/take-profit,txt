fib4 = input.float(2.000, "Fib TP4", minval = 0.5, step = 0.001, group = grpTiers, inline = "fib4")
fib5 = input.float(2.618, "Fib TP5", minval = 0.5, step = 0.001, group = grpTiers, inline = "fib5")
fib6 = input.float(3.618, "Fib TP6", minval = 0.5, step = 0.001, group = grpTiers, inline = "fib6")
fib7 = input.float(4.236, "Fib TP7", minval = 0.5, step = 0.001, group = grpTiers, inline = "fib7")

r1 = input.float(1.0, "R-Mult TP1", minval = 0.1, step = 0.1, group = grpTiers, inline = "r1")
r2 = input.float(2.0, "R-Mult TP2", minval = 0.1, step = 0.1, group = grpTiers, inline = "r2")
r3 = input.float(3.0, "R-Mult TP3", minval = 0.1, step = 0.1, group = grpTiers, inline = "r3")
r4 = input.float(5.0, "R-Mult TP4", minval = 0.1, step = 0.1, group = grpTiers, inline = "r4")
r5 = input.float(8.0, "R-Mult TP5", minval = 0.1, step = 0.1, group = grpTiers, inline = "r5")
r6 = input.float(13.0, "R-Mult TP6", minval = 0.1, step = 0.1, group = grpTiers, inline = "r6")
r7 = input.float(21.0, "R-Mult TP7", minval = 0.1, step = 0.1, group = grpTiers, inline = "r7")

// ── Position sizing ──
alloc1 = input.float(20, "Alloc TP1 %", minval = 0, maxval = 100, step = 1, group = grpAlloc, inline = "a1")
alloc2 = input.float(20, "Alloc TP2 %", minval = 0, maxval = 100, step = 1, group = grpAlloc, inline = "a2")
alloc3 = input.float(25, "Alloc TP3 %", minval = 0, maxval = 100, step = 1, group = grpAlloc, inline = "a3")
alloc4 = input.float(20, "Alloc TP4 %", minval = 0, maxval = 100, step = 1, group = grpAlloc, inline = "a4")
alloc5 = input.float(15, "Alloc TP5 %", minval = 0, maxval = 100, step = 1, group = grpAlloc, inline = "a5")
alloc6 = input.float(0,  "Alloc TP6 %", minval = 0, maxval = 100, step = 1, group = grpAlloc, inline = "a6")
alloc7 = input.float(0,  "Alloc TP7 %", minval = 0, maxval = 100, step = 1, group = grpAlloc, inline = "a7",
